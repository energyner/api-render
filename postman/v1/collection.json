    },



    {
      "name": "Negative Testing",

      "item": [

        {
          "name": "Endpoint inexistente",

          "request": {

            "method": "GET",

            "url": {
              "raw": "{{base_url}}/invalid",
              "host": ["{{base_url}}"],
              "path": ["invalid"]
            }
          },

          "event": [
            {
              "listen": "test",

              "script": {
                "exec": [

                  "// =============================",
                  "// STATUS 404",
                  "// =============================",

                  "pm.test('Status 404', () => pm.response.to.have.status(404));"

                ]
              }
            }
          ]
        }

      ]
    }

  ]
}